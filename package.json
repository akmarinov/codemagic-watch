{
  "name": "codemagic-watcher",
  "version": "0.1.0",
  "description": "Minimal CLI helper for polling Codemagic builds, streaming status updates, and reacting to failures.",
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/cli.js",
  "bin": {
    "codemagic-watch": "dist/cli.js"
  },
  "scripts": {
    "pretest": "npm run build --silent",
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "start": "node dist/cli.js",
    "test": "node dist/cli.js --help"
  },
  "keywords": [
    "codemagic",
    "cli",
    "ci",
    "watcher"
  ],
  "author": "",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.2"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  }
}
